# Archivo de ejemplo para variables de entorno locales
# Copia este archivo como .env y configura tus valores locales

# Base de datos local
DATABASE_URL=jdbc:postgresql://localhost:5432/rizoma_dev
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=tu_password_local

# Directorio de archivos
FILE_UPLOAD_DIRECTORY=./uploads

# Clave secreta para JWT (genera una nueva para producción)
SECRET_JWT_KEY=mi-clave-secreta-para-desarrollo-local-muy-larga-y-segura

# Configuración de Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password

# URL del Frontend (para enlaces en emails)
FRONTEND_URL=http://localhost:5173
